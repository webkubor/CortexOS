{
  "name": "cortexos",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x",
    "pnpm": "10.x"
  },
  "scripts": {
    "dev": "node scripts/actions/vitepress-with-fleet-bridge.mjs dev",
    "docs:build": "vitepress build docs",
    "docs:preview": "node scripts/actions/vitepress-with-fleet-bridge.mjs preview",
    "health:core": "node scripts/tools/health-check.js --strict",
    "health:docs-index": "node scripts/maintenance/check-docs-index.js",
    "health:skills": "node scripts/maintenance/check-skill-paths.mjs",
    "health:verify": "node scripts/maintenance/verify-health.js",
    "health:gate": "node scripts/maintenance/health-gate.js",
    "health:mcp": "uv run mcp_server/server.py --help || echo 'MCP server smoke test failed'",
    "mcp:reload": "node scripts/actions/reload-brain-mcp.mjs",
    "memory:index": "python3 scripts/ingest/build_memory_index.py",
    "memory:query": "python3 scripts/ingest/query_brain.py",
    "memory:refresh": "python3 scripts/ingest/chroma_ingest.py && python3 scripts/ingest/build_memory_index.py",
    "memory:retro": "node scripts/maintenance/error-retro.mjs",
    "tasks:reconcile": "node scripts/maintenance/reconcile-ai-team-tasks.mjs",
    "fleet:claim": "node scripts/actions/fleet-claim.mjs",
    "fleet:status": "node scripts/actions/fleet-status.mjs",
    "fleet:handover": "node scripts/actions/fleet-handover.mjs",
    "team:db:init": "node scripts/actions/init-ai-team-db.mjs",
    "fleet:cleanup": "node scripts/actions/fleet-cleanup.mjs",
    "fleet:post-task": "node scripts/actions/fleet-post-task.mjs",
    "fleet:checkin": "node scripts/actions/fleet-checkin.mjs",
    "fleet:bridge": "node scripts/services/fleet-control-bridge.mjs",
    "team:local": "node scripts/actions/team-local.mjs",
    "projects:sync": "node scripts/actions/project-registry.mjs",
    "fleet:sync-dashboard": "node scripts/actions/sync-fleet-dashboard.mjs",
    "feishu:bot": "node scripts/services/feishu-bot-bridge.mjs",
    "skills:sync": "node scripts/tools/sync-skills-management.mjs",
    "gemini:auto": "scripts/actions/gemini-with-fleet.sh",
    "claude:auto": "scripts/actions/claude-with-fleet.sh",
    "codex:auto": "scripts/actions/codex-with-fleet.sh",
    "codex:setup": "bash scripts/actions/setup-codex-alias.sh",
    "init:profile": "node scripts/core/init-owner-profile.mjs"
  },
  "devDependencies": {
    "vitepress": "^1.6.4",
    "vitepress-plugin-llms": "^1.11.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
