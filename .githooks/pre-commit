#!/usr/bin/env bash
# ============================================================
# CortexOS Git Pre-commit Security Hook
# 作用：在每次 git commit 前自动扫描敏感内容，拦截不安全提交
# 安装：cp .githooks/pre-commit.sh .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# 或配置：git config core.hooksPath .githooks
# ============================================================

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

ERRORS=()
WARNINGS=()

# 获取本次要提交的文件列表（排除删除的文件）
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)

if [[ -z "$STAGED_FILES" ]]; then
  exit 0
fi

# ─── 规则 1：绝对路径硬编码 ──────────────────────────────────
# 检测 /Users/<username>/... 形式的硬编码路径（注释行除外）
while IFS= read -r file; do
  # 跳过二进制文件和锁文件
  [[ "$file" == *.png || "$file" == *.jpg || "$file" == *.svg || "$file" == *.ico ]] && continue
  [[ "$file" == *pnpm-lock* || "$file" == *package-lock* || "$file" == *.bin ]] && continue
  [[ "$file" == .venv/* || "$file" == chroma_db/* ]] && continue

  if git show ":$file" 2>/dev/null | grep -qE '/Users/[a-zA-Z0-9_-]+/(Documents|Desktop|Downloads|Library)'; then
    # 允许：README 里的示例路径、注释里的示例
    MATCHES=$(git show ":$file" | grep -nE '/Users/[a-zA-Z0-9_-]+/(Documents|Desktop|Downloads|Library)' | grep -v '^\s*#' | grep -v '^\s*//' || true)
    if [[ -n "$MATCHES" ]]; then
      ERRORS+=("🔴 硬编码绝对路径 in $file:\n$MATCHES")
    fi
  fi
done <<< "$STAGED_FILES"

# ─── 规则 2：私钥关键词 ──────────────────────────────────────
SECRET_PATTERNS=(
  'PRIVATE'" KEY"
  'BEGIN'" RSA"
  'sk-[a-zA-Z0-9]{20,}'
  'ghp_[a-zA-Z0-9]{30,}'
  'ghs_[a-zA-Z0-9]{30,}'
  'AIza[a-zA-Z0-9_-]{30,}'
  'api[_-]?key\s*=\s*["\x27][a-zA-Z0-9_-]{16,}'
  'secret\s*=\s*["\x27][a-zA-Z0-9_-]{16,}'
  'password\s*=\s*["\x27][^"\x27]{8,}'
  'token\s*=\s*["\x27][a-zA-Z0-9_-]{16,}'
  'WEBHOOK_'"URL"'.*hooks\.'
)

while IFS= read -r file; do
  [[ "$file" == *.png || "$file" == *.jpg || "$file" == *.bin ]] && continue
  [[ "$file" == *pnpm-lock* || "$file" == .venv/* || "$file" == chroma_db/* ]] && continue

  for pattern in "${SECRET_PATTERNS[@]}"; do
    MATCHES=$(git show ":$file" 2>/dev/null | grep -inE "$pattern" | grep -v '^\s*#' | grep -v 'example\|placeholder\|YOUR_' || true)
    if [[ -n "$MATCHES" ]]; then
      ERRORS+=("🔴 疑似私钥/凭据 in $file (pattern: $pattern):\n$MATCHES")
      break
    fi
  done
done <<< "$STAGED_FILES"

# ─── 规则 3：个人 ID 出现在非预期文件 ─────────────────────────
# docs/about.md 和 README.md 允许有 webkubor（作者署名）
# 但其他配置/脚本文件里不应硬编码 GitHub ID
PERSONAL_ID_EXCEPTIONS=("README.md" "docs/about.md" "docs/guide/index.md" "docs/skills/github_repos.md" "docs/assets/onboarding_guide.md" "scripts/maintenance/skill-health-check.sh")

while IFS= read -r file; do
  [[ "$file" == *.png || "$file" == *.jpg || "$file" == *pnpm-lock* || "$file" == .venv/* || "$file" == chroma_db/* ]] && continue

  # 检查是否在白名单里
  skip=0
  for exc in "${PERSONAL_ID_EXCEPTIONS[@]}"; do
    [[ "$file" == "$exc" ]] && skip=1 && break
  done
  [[ "$skip" == 1 ]] && continue

  MATCHES=$(git show ":$file" 2>/dev/null | grep -n "老爹\|/Users/webkubor" | grep -v '^\s*#' | grep -v '^\s*//' || true)
  if [[ -n "$MATCHES" ]]; then
    WARNINGS+=("🟡 个人标识 in $file:\n$MATCHES")
  fi
done <<< "$STAGED_FILES"

# ─── 输出结果 ────────────────────────────────────────────────
echo ""
if [[ ${#ERRORS[@]} -gt 0 ]]; then
  echo -e "${RED}╔═══════════════════════════════════════════╗"
  echo -e "║  🚨 Pre-commit 安全检查: 发现严重问题     ║"
  echo -e "╚═══════════════════════════════════════════╝${NC}"
  for err in "${ERRORS[@]}"; do
    echo -e "${RED}${err}${NC}"
    echo ""
  done
  echo -e "${RED}❌ 提交已被拦截。请修复以上问题后重新提交。${NC}"
  echo -e "${YELLOW}   提示：如需强制提交（知晓风险），使用 git commit --no-verify${NC}"
  echo ""
  exit 1
fi

if [[ ${#WARNINGS[@]} -gt 0 ]]; then
  echo -e "${YELLOW}╔═══════════════════════════════════════════╗"
  echo -e "║  ⚠️  Pre-commit 安全检查: 发现警告        ║"
  echo -e "╚═══════════════════════════════════════════╝${NC}"
  for warn in "${WARNINGS[@]}"; do
    echo -e "${YELLOW}${warn}${NC}"
    echo ""
  done
  echo -e "${YELLOW}⚠️  以上为警告，提交将继续。建议检查后处理。${NC}"
  echo ""
fi

echo -e "${GREEN}✅ Pre-commit 安全检查通过${NC}"
exit 0
