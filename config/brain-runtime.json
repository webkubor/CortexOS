{
  "version": "1.0",
  "assistant": {
    "name": "Candy",
    "agent": "Codex"
  },
  "memory": {
    "knowledgeRoot": "../memory/knowledge",
    "secretsRoot": "../memory/secrets",
    "logsRoot": "$CODEX_HOME/.memory/logs",
    "assistantPrivateRoot": "$CODEX_HOME/.memory",
    "userMemoryWritePolicy": "user_explicit_only"
  },
  "daemons": {
    "brain-cortex-pilot": {
      "enabled": true,
      "managedBy": "pm2",
      "script": "scripts/core/auto-pilot.js",
      "schedule": "*/5 * * * *",
      "purpose": "大脑内核同步、栖洲资产保护、僵尸进程清理、环境态势感知"
    },
    "brain-frontend": {
      "enabled": true,
      "managedBy": "pm2",
      "script": "pnpm brain:frontend",
      "port": 5181,
      "url": "http://127.0.0.1:5181/CortexOS/brain/",
      "purpose": "CortexOS 中央大脑前台常驻页面"
    }
  }
}
